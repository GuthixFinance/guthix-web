<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GUTHIX — Swap</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Syne:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0E0B14;
      --bg2:      #13101C;
      --surface:  #1C1826;
      --surface2: #241F32;
      --surface3: #2C2740;
      --border:   rgba(255,255,255,0.07);
      --border2:  rgba(255,255,255,0.12);
      --text:     #EAE8F2;
      --text2:    #8B87A8;
      --text3:    #524E6B;
      --accent:   #4FFFA4;
      --accent2:  #00D4FF;
      --purple:   #9B7FFF;
      --gold:     #F0B240;
      --warn:     #FF6B35;
      --font-display: 'Syne', sans-serif;
      --font-body:    'DM Sans', sans-serif;
      --font-mono:    'DM Mono', monospace;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ── NOISE + GRID ── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0; opacity: 0.5;
    }
    .grid-bg {
      position: fixed; inset: 0;
      background-image:
        linear-gradient(rgba(155,127,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(155,127,255,0.025) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none; z-index: 0;
    }

    /* ── ORBS ── */
    .orb {
      position: fixed; border-radius: 50%;
      filter: blur(100px); pointer-events: none; z-index: 0;
      animation: drift 18s ease-in-out infinite;
    }
    .orb-1 { width: 500px; height: 500px; background: rgba(155,127,255,0.08); top: -100px; right: -80px; }
    .orb-2 { width: 400px; height: 400px; background: rgba(79,255,164,0.05); bottom: 10%; left: -100px; animation-delay: -9s; }
    @keyframes drift {
      0%,100% { transform: translate(0,0) scale(1); }
      50% { transform: translate(20px,-20px) scale(1.05); }
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 28px;
      height: 60px;
      background: rgba(14,11,20,0.75);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .nav-left { display: flex; align-items: center; gap: 20px; }
    .nav-logo {
      display: flex; align-items: center; gap: 9px;
      font-family: var(--font-display);
      font-size: 17px; font-weight: 800;
      letter-spacing: 0.12em;
      color: var(--text);
      text-decoration: none;
    }
    .nav-logo-mark {
      width: 26px; height: 26px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 800; color: #080B12;
    }
    .nav-divider { width: 1px; height: 20px; background: var(--border2); }
    .nav-links { display: flex; gap: 4px; }
    .nav-link {
      font-family: var(--font-mono);
      font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--text3); text-decoration: none;
      padding: 6px 12px; border-radius: 6px;
      transition: all 0.15s;
    }
    .nav-link:hover { color: var(--text2); background: var(--surface); }
    .nav-link.active { color: var(--text); background: var(--surface2); }

    .nav-right { display: flex; align-items: center; gap: 12px; }
    .nav-icon-btn {
      width: 34px; height: 34px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: all 0.15s;
      color: var(--text2); font-size: 15px;
      text-decoration: none;
    }
    .nav-icon-btn:hover { border-color: var(--border2); color: var(--text); }
    .connect-btn {
      font-family: var(--font-mono);
      font-size: 11px; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--bg); background: var(--purple);
      border: none; padding: 0 20px; height: 34px;
      border-radius: 8px; cursor: pointer;
      transition: all 0.15s;
    }
    .connect-btn:hover { background: #B09AFF; transform: translateY(-1px); }

    /* ── MAIN LAYOUT ── */
    main {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 80px 20px 40px;
      position: relative; z-index: 1;
    }

    .app-wrapper {
      width: 100%;
      max-width: 460px;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    /* ── TAB TOGGLE ── */
    .tab-toggle {
      display: flex;
      background: var(--surface2);
      border-radius: 12px 12px 0 0;
      border: 1px solid var(--border2);
      border-bottom: none;
      overflow: hidden;
      position: relative;
    }
    .tab-btn {
      flex: 1;
      padding: 14px 0;
      font-family: var(--font-mono);
      font-size: 12px; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--text3);
      background: transparent;
      border: none; cursor: pointer;
      transition: all 0.2s;
      position: relative; z-index: 1;
    }
    .tab-btn.active { color: var(--text); }
    .tab-slider {
      position: absolute;
      top: 6px; bottom: 6px;
      width: calc(50% - 8px);
      background: var(--surface3);
      border-radius: 8px;
      border: 1px solid var(--border2);
      transition: left 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
      left: 6px;
    }
    .tab-slider.right { left: calc(50% + 2px); }

    /* ── MAIN CARD ── */
    .swap-card {
      background: var(--surface);
      border: 1px solid var(--border2);
      border-top: none;
      border-radius: 0 0 16px 16px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    /* ── TOKEN SELECTOR ROW ── */
    .token-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }
    .token-pills { display: flex; gap: 6px; }
    .token-pill {
      display: flex; align-items: center; gap: 7px;
      font-family: var(--font-mono);
      font-size: 12px; font-weight: 500;
      letter-spacing: 0.06em;
      color: var(--text2);
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 6px 14px 6px 8px;
      cursor: pointer; transition: all 0.15s;
    }
    .token-pill:hover { border-color: var(--border2); color: var(--text); }
    .token-pill.active {
      background: var(--surface3);
      border-color: var(--border2);
      color: var(--text);
    }
    .token-icon {
      width: 20px; height: 20px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700;
    }
    .token-icon-usdc { background: linear-gradient(135deg, #2775CA, #5BA4E6); color: white; }
    .token-icon-usdt { background: linear-gradient(135deg, #26A17B, #4FD1A5); color: white; }

    .priority-row { display: flex; align-items: center; gap: 8px; }
    .priority-label {
      font-family: var(--font-mono);
      font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--text3);
    }
    .priority-pills { display: flex; gap: 3px; }
    .priority-pill {
      font-family: var(--font-mono);
      font-size: 10px; letter-spacing: 0.06em;
      color: var(--text3);
      background: transparent;
      border: 1px solid transparent;
      border-radius: 6px;
      padding: 4px 10px;
      cursor: pointer; transition: all 0.15s;
    }
    .priority-pill:hover { color: var(--text2); }
    .priority-pill.active {
      color: var(--accent);
      background: rgba(79,255,164,0.08);
      border-color: rgba(79,255,164,0.2);
    }

    /* ── INPUT BLOCKS ── */
    .input-block {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 18px 20px;
      margin-bottom: 8px;
      transition: border-color 0.2s;
    }
    .input-block:focus-within { border-color: var(--border2); }
    .input-block-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 14px;
    }
    .input-block-label {
      font-family: var(--font-mono);
      font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--text2); font-weight: 500;
    }
    .input-block-balance {
      display: flex; align-items: center; gap: 6px;
      font-family: var(--font-mono);
      font-size: 11px; color: var(--text3);
    }
    .balance-icon {
      width: 16px; height: 16px;
      border: 1px solid var(--border2);
      border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
      font-size: 9px;
    }
    .input-row {
      display: flex; align-items: center; gap: 12px;
    }
    .token-circle {
      width: 40px; height: 40px; border-radius: 50%;
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; font-weight: 700;
    }
    .token-circle-usdc  { background: linear-gradient(135deg, #2775CA, #5BA4E6); color: white; font-size: 14px; }
    .token-circle-usdt  { background: linear-gradient(135deg, #26A17B, #4FD1A5); color: white; font-size: 14px; }
    .token-circle-sol   { background: linear-gradient(135deg, #9945FF, #14F195); color: white; font-size: 14px; }
    .token-circle-bonk  { background: linear-gradient(135deg, #F7A12B, #F7D32B); color: #111; font-size: 13px; }
    .token-circle-jito  { background: linear-gradient(135deg, #22C55E, #16A34A); color: white; font-size: 12px; }
    .token-circle-other { background: var(--surface3); color: var(--text2); font-size: 13px; }
    .token-circle-sgx {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: #080B12; font-size: 13px; letter-spacing: -0.02em;
    }

    /* ── TOKEN SELECTOR BUTTON (replaces old pills on swap-in) ── */
    .token-select-btn {
      display: flex; align-items: center; gap: 8px;
      background: var(--surface2);
      border: 1px solid var(--border2);
      border-radius: 100px;
      padding: 6px 12px 6px 6px;
      cursor: pointer;
      transition: all 0.15s;
      font-family: var(--font-mono);
      font-size: 13px; font-weight: 500;
      color: var(--text);
      letter-spacing: 0.04em;
    }
    .token-select-btn:hover { border-color: var(--accent); background: var(--surface3); }
    .token-select-btn .chevron { color: var(--text3); font-size: 10px; margin-left: 2px; }
    .token-select-icon {
      width: 24px; height: 24px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700; flex-shrink: 0;
    }

    /* ── TOKEN PICKER MODAL ── */
    .token-modal-overlay {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(6px);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s;
    }
    .token-modal-overlay.open { opacity: 1; pointer-events: all; }
    .token-modal {
      width: 360px;
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: 16px;
      overflow: hidden;
      transform: translateY(12px);
      transition: transform 0.2s;
    }
    .token-modal-overlay.open .token-modal { transform: translateY(0); }
    .token-modal-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 20px 14px;
      border-bottom: 1px solid var(--border);
    }
    .token-modal-title {
      font-family: var(--font-display);
      font-size: 15px; font-weight: 700; color: var(--text);
    }
    .token-modal-close {
      width: 28px; height: 28px; border-radius: 8px;
      border: 1px solid var(--border); background: var(--surface2);
      color: var(--text2); font-size: 16px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.15s;
    }
    .token-modal-close:hover { border-color: var(--border2); color: var(--text); }
    .token-search-wrap {
      padding: 12px 16px 8px;
      border-bottom: 1px solid var(--border);
    }
    .token-search {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 9px 14px;
      font-family: var(--font-mono);
      font-size: 12px; color: var(--text);
      outline: none; transition: border-color 0.15s;
    }
    .token-search::placeholder { color: var(--text3); }
    .token-search:focus { border-color: var(--border2); }
    .token-grid-label {
      font-family: var(--font-mono);
      font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--text3);
      padding: 12px 16px 8px;
    }
    .token-popular-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
      padding: 0 12px 12px;
    }
    .token-grid-item {
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      padding: 10px 8px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--surface2);
      cursor: pointer; transition: all 0.15s;
    }
    .token-grid-item:hover { border-color: var(--border2); background: var(--surface3); }
    .token-grid-item.active { border-color: var(--accent); background: rgba(79,255,164,0.06); }
    .token-grid-icon {
      width: 32px; height: 32px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700;
    }
    .token-grid-name {
      font-family: var(--font-mono);
      font-size: 11px; font-weight: 500;
      color: var(--text); letter-spacing: 0.04em;
    }
    .token-grid-bal {
      font-family: var(--font-mono);
      font-size: 9px; color: var(--text3);
    }
    .token-search-results {
      max-height: 200px; overflow-y: auto;
      border-top: 1px solid var(--border);
    }
    .token-result-row {
      display: flex; align-items: center; gap: 12px;
      padding: 11px 16px;
      cursor: pointer; transition: background 0.1s;
    }
    .token-result-row:hover { background: var(--surface2); }
    .token-result-row.active { background: rgba(79,255,164,0.05); }
    .token-result-icon {
      width: 32px; height: 32px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700; flex-shrink: 0;
      background: var(--surface3); color: var(--text2);
    }
    .token-result-info { flex: 1; }
    .token-result-name { font-family: var(--font-mono); font-size: 12px; color: var(--text); font-weight: 500; }
    .token-result-mint { font-family: var(--font-mono); font-size: 9px; color: var(--text3); margin-top: 1px; }
    .token-result-bal  { font-family: var(--font-mono); font-size: 11px; color: var(--text2); flex-shrink: 0; }
    .token-not-found {
      padding: 20px 16px;
      font-family: var(--font-mono); font-size: 11px;
      color: var(--text3); text-align: center; letter-spacing: 0.06em;
    }
    .input-field {
      flex: 1;
      background: transparent;
      border: none; outline: none;
      font-family: var(--font-mono);
      font-size: 28px; font-weight: 300;
      color: var(--text3);
      width: 100%;
    }
    .input-field::placeholder { color: var(--text3); }
    .input-field:focus { color: var(--text); }
    .input-field.has-value { color: var(--text); }
    .max-btn {
      font-family: var(--font-mono);
      font-size: 10px; font-weight: 500;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--text3);
      background: var(--surface3);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 5px 10px;
      cursor: pointer; transition: all 0.15s;
      flex-shrink: 0;
    }
    .max-btn:hover { color: var(--accent); border-color: rgba(79,255,164,0.3); }

    /* ── RECEIVE BLOCK ── */
    .receive-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 14px;
    }
    .receive-label {
      font-family: var(--font-mono);
      font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--text2); font-weight: 500;
    }
    .apy-badge {
      display: flex; align-items: center; gap: 6px;
      font-family: var(--font-mono);
      font-size: 11px;
    }
    .apy-label { color: var(--text3); letter-spacing: 0.1em; }
    .apy-value {
      color: var(--accent);
      font-weight: 500;
      font-size: 14px;
    }
    .apy-pulse {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent);
      animation: glow-pulse 2s ease-in-out infinite;
    }
    @keyframes glow-pulse {
      0%,100% { box-shadow: 0 0 0 0 rgba(79,255,164,0.4); }
      50% { box-shadow: 0 0 0 4px rgba(79,255,164,0); }
    }
    .receive-value {
      font-family: var(--font-mono);
      font-size: 28px; font-weight: 300;
      color: var(--text3);
      transition: color 0.2s;
    }
    .receive-value.has-value { color: var(--text); }

    /* ── SWAP ARROW ── */
    .swap-arrow-wrap {
      display: flex; justify-content: center;
      margin: -4px 0;
      position: relative; z-index: 2;
    }
    .swap-arrow-btn {
      width: 34px; height: 34px;
      background: var(--surface3);
      border: 1px solid var(--border2);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      color: var(--text2);
      transition: all 0.2s;
      font-size: 14px;
    }
    .swap-arrow-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
      transform: rotate(180deg);
    }

    /* ── CAPACITY BAR ── */
    .capacity-block {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 16px;
      margin-bottom: 8px;
    }
    .capacity-row {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 8px;
    }
    .capacity-label {
      font-family: var(--font-mono);
      font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--text3);
    }
    .capacity-value {
      font-family: var(--font-mono);
      font-size: 11px; color: var(--text2);
    }
    .capacity-bar-track {
      height: 3px;
      background: var(--surface3);
      border-radius: 3px;
      overflow: hidden;
    }
    .capacity-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 3px;
      width: 68%;
      animation: barIn 1s ease-out forwards;
      transform-origin: left;
    }
    @keyframes barIn {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }

    /* ── META ROWS ── */
    .meta-rows {
      display: flex; flex-direction: column; gap: 8px;
      margin-bottom: 20px;
      padding: 0 2px;
    }
    .meta-row {
      display: flex; align-items: center; justify-content: space-between;
    }
    .meta-key {
      font-family: var(--font-mono);
      font-size: 11px; color: var(--text3);
      letter-spacing: 0.04em;
    }
    .meta-val {
      font-family: var(--font-mono);
      font-size: 11px; color: var(--text2);
    }
    .meta-val.highlight { color: var(--accent2); }

    /* ── SWAP BUTTON ── */
    .swap-btn {
      width: 100%;
      padding: 16px;
      border-radius: 12px;
      border: none;
      font-family: var(--font-mono);
      font-size: 13px; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s;
      position: relative; overflow: hidden;
    }
    .swap-btn-in {
      background: linear-gradient(135deg, rgba(79,255,164,0.15), rgba(0,212,255,0.1));
      border: 1px solid rgba(79,255,164,0.3);
      color: var(--accent);
    }
    .swap-btn-in:hover {
      background: linear-gradient(135deg, rgba(79,255,164,0.25), rgba(0,212,255,0.18));
      border-color: var(--accent);
      transform: translateY(-1px);
      box-shadow: 0 8px 32px rgba(79,255,164,0.15);
    }
    .swap-btn-out {
      background: linear-gradient(135deg, rgba(155,127,255,0.15), rgba(0,212,255,0.1));
