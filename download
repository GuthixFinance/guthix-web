  <script>
    // ═══════════════════════════════════════════════════════════════════════
    // CONFIG
    // ═══════════════════════════════════════════════════════════════════════
    const CONFIG = {
      RPC:             'https://mainnet.helius-rpc.com/?api-key=6df6c556-796b-48f1-a24a-21ffe0995f66',
      SGXUSD_MINT:     'Eh6XEPhSwoLv5wFApukmnaVSHQ6sAnoD9BmgmwQoN2sN',
      SGXUSD_DECIMALS: 9,
      JUPITER_QUOTE:   'https://lite-api.jup.ag/swap/v1/quote',
      JUPITER_TOKENS:  'https://lite-api.jup.ag/tokens/v1/tagged/verified',
      NAV_REFRESH_MS:  30_000,
    };

    // Popular tokens shown in the grid
    const POPULAR_TOKENS = [
      { symbol: 'SOL',     name: 'Solana',          mint: 'So11111111111111111111111111111111111111112',  decimals: 9,  iconBg: 'linear-gradient(135deg,#9945FF,#14F195)', iconColor: 'white',  iconText: '◎' },
      { symbol: 'USDC',    name: 'USD Coin',         mint: 'EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v', decimals: 6, iconBg: 'linear-gradient(135deg,#2775CA,#5BA4E6)', iconColor: 'white',  iconText: '$' },
      { symbol: 'USDT',    name: 'Tether',           mint: 'Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB', decimals: 6, iconBg: 'linear-gradient(135deg,#26A17B,#4FD1A5)', iconColor: 'white',  iconText: '₮' },
      { symbol: 'BONK',    name: 'Bonk',             mint: 'DezXAZ8z7PnrnRJjz3wXBoRgixCa6xjnB7YaB1pPB263',  decimals: 5, iconBg: 'linear-gradient(135deg,#F7A12B,#F7D32B)', iconColor: '#111',   iconText: '🐕' },
      { symbol: 'JitoSOL', name: 'Jito Staked SOL', mint: 'J1toso1uCk3RLmjorhTtrVwY9HJ7X8V9yYac6Y7kGCPn',  decimals: 9, iconBg: 'linear-gradient(135deg,#22C55E,#16A34A)', iconColor: 'white',  iconText: '⚡' },
    ];

    // Out tokens (Swap Out only)
    const OUT_TOKENS = {
      USDC: { symbol: 'USDC', mint: 'EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v', decimals: 6 },
      USDT: { symbol: 'USDT', mint: 'Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB', decimals: 6 },
    };

    // ═══════════════════════════════════════════════════════════════════════
    // STATE
    // ═══════════════════════════════════════════════════════════════════════
    const state = {
      tab:         'in',
      inputToken:  POPULAR_TOKENS[1],   // default USDC for swap-in
      outToken:    'USDC',              // swap-out output token
      navRate:     null,
      navPrice:    null,
      navStale:    false,
      navLastUpdated: null,
      wallet:      null,
      walletProvider: null,
      tokenBalances: {},                // mint → uiAmount string
      allTokens:   [],                  // Jupiter verified token list for search
    };

    // ═══════════════════════════════════════════════════════════════════════
    // UTILS
    // ═══════════════════════════════════════════════════════════════════════
    async function fetchWithRetry(url, options = {}, maxRetries = 3) {
      for (let attempt = 0; attempt < maxRetries; attempt++) {
        try {
          const res = await fetch(url, options);
          if (res.ok) return res;
          if (res.status === 429) {
            const delay = Math.pow(2, attempt) * 1000;
            await sleep(delay);
            continue;
          }
          if (res.status >= 500) {
            await sleep(Math.pow(2, attempt) * 1000);
            continue;
          }
          throw new Error(`HTTP ${res.status}`);
        } catch (err) {
          if (attempt === maxRetries - 1) throw err;
          await sleep(Math.pow(2, attempt) * 1000);
        }
      }
      throw new Error('Max retries exceeded');
    }

    function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

    function setDataStatus(id, status) {
      const el = document.getElementById(id);
      if (!el) return;
      const colors = { loading: 'var(--text3)', live: 'var(--accent)', stale: 'var(--gold)', error: 'var(--warn)' };
      const labels = { loading: '●', live: '●', stale: '◌', error: '✕' };
      el.style.color = colors[status];
      el.textContent = labels[status];
      el.title = status.charAt(0).toUpperCase() + status.slice(1);
    }

    // ═══════════════════════════════════════════════════════════════════════
    // EXCHANGE RATE — Jupiter Quote API
    // Quotes a 1 USDC → sgxUSD swap to derive the real exchange rate.
    // No API key needed. Works as long as Jupiter has a route for the token
    // (any DEX pool — Meteora, Raydium, Orca, etc.).
    // If no route exists yet, shows a pre-launch placeholder.
    // ═══════════════════════════════════════════════════════════════════════
    const QUOTE_AMOUNT_USDC = 1_000_000; // 1 USDC in base units (6 decimals)

    async function fetchNavRate() {
      setDataStatus('navStatus', 'loading');
      // Always quote USDC→sgxUSD for the canonical rate regardless of selected token
      try {
        const url = `${CONFIG.JUPITER_QUOTE}?inputMint=${OUT_TOKENS.USDC.mint}&outputMint=${CONFIG.SGXUSD_MINT}&amount=${QUOTE_AMOUNT_USDC}&slippageBps=50`;
        const res = await fetch(url);
        const text = await res.text();
        console.log('[GUTHIX] Quote response:', res.status, text.slice(0, 300));
        if (!res.ok) throw new Error(`HTTP ${res.status}: ${text.slice(0, 100)}`);
        const data = JSON.parse(text);

        if (data.error || !data.outAmount) throw new Error(JSON.stringify(data).slice(0, 150));

        const sgxOut     = parseInt(data.outAmount, 10) / Math.pow(10, CONFIG.SGXUSD_DECIMALS);
        state.navPrice   = 1 / sgxOut;
        state.navRate    = sgxOut;
        state.navStale   = false;
        state.navLastUpdated = Date.now();
        setDataStatus('navStatus', 'live');

      } catch (err) {
        console.warn('[GUTHIX] Quote fetch failed:', err.message);
        state.navStale = true;
        setDataStatus('navStatus', state.navRate === null ? 'error' : 'stale');
      }
      renderNavRate();
    }

    function renderNavRate() {
      const rateEl = document.getElementById('exchangeRate');
      const apyEl  = document.querySelector('.apy-value');

      if (state.navPrice == null) {
        rateEl.textContent = '⇌ Pre-launch — no route yet';
        apyEl.textContent  = '—%';
        return;
      }

      const stale = state.navStale ? ' ~' : '';
      rateEl.textContent = `⇌${stale} 1 sgxUSD = $${state.navPrice.toFixed(6)}`;
      apyEl.textContent = '—%';
    }

    // ═══════════════════════════════════════════════════════════════════════
    // WALLET DETECTION & CONNECTION
    // ═══════════════════════════════════════════════════════════════════════
    // WALLET — simple direct window inspection, no Wallet Standard complexity
    // Extensions inject into window.* synchronously before DOMContentLoaded
    // on pages served over HTTP. On file:// they may not inject at all.
    // ═══════════════════════════════════════════════════════════════════════

    const KNOWN_WALLETS = [
      {
        name: 'Phantom', icon: '👻', installUrl: 'https://phantom.app/',
        detect() {
          const p = window.phantom?.solana;
          if (p?.isPhantom) return p;
          if (window.solana?.isPhantom) return window.solana;
          return null;
        }
      },
      {
        name: 'Backpack', icon: '🎒', installUrl: 'https://backpack.app/',
        detect() {
          if (window.backpack?.isBackpack) return window.backpack;
          if (window.xnft?.solana) return window.xnft.solana;
          if (window.solana?.isBackpack) return window.solana;
          return null;
        }
      },
      {
        name: 'Brave Wallet', icon: '🦁', installUrl: 'https://brave.com/wallet/',
        detect() {
          if (window.braveSolana) return window.braveSolana;
          if (window.solana?.isBraveWallet) return window.solana;
          return null;
        }
      },
      {
        name: 'Solflare', icon: '🌟', installUrl: 'https://solflare.com/',
        detect() {
          if (window.solflare?.isSolflare) return window.solflare;
          return null;
        }
      },
    ];

    function initWalletStandard() {} // no-op, kept for boot call compat

    function openWalletModal() {
      // Debug dump — paste this in console if wallets still not detected
      console.log('[GUTHIX] window.solana:', window.solana);
      console.log('[GUTHIX] window.phantom:', window.phantom);
      console.log('[GUTHIX] window.backpack:', window.backpack);
      console.log('[GUTHIX] window.xnft:', window.xnft);
      console.log('[GUTHIX] window.braveSolana:', window.braveSolana);
      console.log('[GUTHIX] window.solflare:', window.solflare);

      const list = document.getElementById('walletList');
      list.innerHTML = '';

      KNOWN_WALLETS.forEach(w => {
        const provider = w.detect();
        console.log(`[GUTHIX] ${w.name} detected:`, !!provider, provider);
        const el = document.createElement('div');
        el.className = 'wallet-option';
        el.innerHTML = `
          <div class="wallet-option-icon">${w.icon}</div>
          <div class="wallet-option-info">
            <div class="wallet-option-name">${w.name}</div>
            <div class="wallet-option-status ${provider ? 'detected' : 'not-installed'}">
              ${provider ? 'Detected' : 'Not installed — click to install'}
            </div>
          </div>
          <div class="wallet-option-arrow">›</div>
        `;
        el.addEventListener('click', () => provider ? connectProvider(w.name, provider) : window.open(w.installUrl, '_blank', 'noopener'));
        list.appendChild(el);
      });

      document.getElementById('walletModal').classList.add('open');
    }

    function closeWalletModal() {
      document.getElementById('walletModal').classList.remove('open');
    }

    function handleModalBackdrop(e) {
      if (e.target === document.getElementById('walletModal')) closeWalletModal();
    }

    async function connectProvider(name, provider) {
      closeWalletModal();
      console.log(`[GUTHIX] Connecting ${name}`, provider);
      try {
        const resp = await provider.connect();
        console.log(`[GUTHIX] Connect response:`, resp);
        const pubkey = resp?.publicKey?.toString()
          ?? provider.publicKey?.toString()
          ?? resp?.publicKey
          ?? provider.publicKey;
        if (!pubkey) throw new Error('No public key in response: ' + JSON.stringify(resp));

        state.wallet         = pubkey;
        state.walletProvider = provider;

        provider.on?.('disconnect', () => {
          state.wallet = null; state.walletProvider = null;
          renderWalletBtn(); updateBalances();
        });
        provider.on?.('accountChanged', pk => {
          state.wallet = pk?.toString() ?? null;
          renderWalletBtn(); updateBalances();
        });

        renderWalletBtn();
        updateBalances();
      } catch (err) {
        console.warn(`[GUTHIX] ${name} connect error:`, err);
      }
    }

    async function connectWallet() {
      if (state.wallet) {
        try { await state.walletProvider?.disconnect?.(); } catch (_) {}
        state.wallet = null; state.walletProvider = null;
        renderWalletBtn(); updateBalances();
        return;
      }
      openWalletModal();
    }

    function truncatePubkey(pk) {
      return `${pk.slice(0, 4)}...${pk.slice(-4)}`;
    }

    function renderWalletBtn() {
      const btn = document.getElementById('connectWalletBtn');
      if (state.wallet) {
        btn.textContent = truncatePubkey(state.wallet);
        btn.style.background = 'var(--surface3)';
        btn.style.color = 'var(--accent)';
        btn.style.border = '1px solid rgba(79,255,164,0.3)';
      } else {
        btn.textContent = 'Connect';
        btn.style.background = 'var(--purple)';
        btn.style.color = 'var(--bg)';
        btn.style.border = 'none';
      }
      renderSwapBtn();
    }

    function renderSwapBtn() {
      const isIn = state.tab === 'in';
      const btn  = document.getElementById('swapBtn');
      btn.className = `swap-btn ${isIn ? 'swap-btn-in' : 'swap-btn-out'}`;
      btn.textContent = !state.wallet
        ? (isIn ? 'Swap In — Connect Wallet' : 'Swap Out — Connect Wallet')
        : (isIn ? 'Swap In' : 'Swap Out');
    }

    // ═══════════════════════════════════════════════════════════════════════
    // ═══════════════════════════════════════════════════════════════════════
    // TOKEN PICKER MODAL
    // ═══════════════════════════════════════════════════════════════════════
    function buildPopularGrid() {
      const grid = document.getElementById('tokenPopularGrid');
      grid.innerHTML = '';
      POPULAR_TOKENS.forEach(t => {
        const bal = state.tokenBalances[t.mint];
        const el  = document.createElement('div');
        el.className = 'token-grid-item' + (state.inputToken?.mint === t.mint ? ' active' : '');
        el.innerHTML = `
          <div class="token-grid-icon" style="background:${t.iconBg};color:${t.iconColor}">${t.iconText}</div>
          <div class="token-grid-name">${t.symbol}</div>
          <div class="token-grid-bal">${bal != null ? parseFloat(bal).toFixed(2) : '—'}</div>
        `;
        el.onclick = () => { selectInputToken(t); closeTokenModal(); };
        grid.appendChild(el);
      });
    }

    async function fetchAllTokens() {
      if (state.allTokens.length > 0) return;
      try {
        const res  = await fetch(CONFIG.JUPITER_TOKENS);
        const data = await res.json();
        state.allTokens = Array.isArray(data) ? data : [];
      } catch (e) { console.warn('[GUTHIX] Token list fetch failed:', e.message); }
    }

    function handleTokenSearch() {
      const q = document.getElementById('tokenSearchInput').value.trim().toLowerCase();
      const popularSection = document.getElementById('tokenPopularSection');
      const resultsEl      = document.getElementById('tokenSearchResults');
      if (!q) {
        popularSection.style.display = ''; resultsEl.style.display = 'none'; resultsEl.innerHTML = ''; return;
      }
      popularSection.style.display = 'none'; resultsEl.style.display = '';
      const pool = [
        ...POPULAR_TOKENS.map(t => ({ symbol: t.symbol, name: t.name, mint: t.mint, decimals: t.decimals, iconBg: t.iconBg, iconColor: t.iconColor, iconText: t.iconText })),
        ...state.allTokens.filter(t =>
          !POPULAR_TOKENS.find(p => p.mint === t.address) &&
          (t.symbol?.toLowerCase().includes(q) || t.name?.toLowerCase().includes(q) || t.address?.toLowerCase() === q)
        ).slice(0, 20).map(t => ({ symbol: t.symbol, name: t.name, mint: t.address, decimals: t.decimals ?? 6, iconBg: 'var(--surface3)', iconColor: 'var(--text2)', iconText: t.symbol?.slice(0,2) ?? '?' })),
      ].filter(t => t.symbol?.toLowerCase().includes(q) || t.name?.toLowerCase().includes(q) || t.mint?.toLowerCase() === q);
      if (!pool.length) { resultsEl.innerHTML = '<div class="token-not-found">No tokens found</div>'; return; }
      resultsEl.innerHTML = '';
      pool.slice(0, 30).forEach(t => {
        const bal = state.tokenBalances[t.mint];
        const el  = document.createElement('div');
        el.className = 'token-result-row' + (state.inputToken?.mint === t.mint ? ' active' : '');
        el.innerHTML = `
          <div class="token-result-icon" style="background:${t.iconBg};color:${t.iconColor}">${t.iconText}</div>
          <div class="token-result-info">
            <div class="token-result-name">${t.symbol}</div>
            <div class="token-result-mint">${t.name} · ${t.mint.slice(0,8)}…</div>
          </div>
          <div class="token-result-bal">${bal != null ? parseFloat(bal).toFixed(4) : ''}</div>
        `;
        el.onclick = () => { selectInputToken(t); closeTokenModal(); };
        resultsEl.appendChild(el);
      });
    }

    function openTokenModal() {
      if (state.tab !== 'in') return;
      buildPopularGrid();
      document.getElementById('tokenSearchInput').value = '';
      document.getElementById('tokenPopularSection').style.display = '';
      document.getElementById('tokenSearchResults').style.display = 'none';
      document.getElementById('tokenSearchResults').innerHTML = '';
      document.getElementById('tokenModal').classList.add('open');
      setTimeout(() => document.getElementById('tokenSearchInput').focus(), 100);
      fetchAllTokens();
    }

    function closeTokenModal() { document.getElementById('tokenModal').classList.remove('open'); }
    function handleTokenModalBackdrop(e) { if (e.target === document.getElementById('tokenModal')) closeTokenModal(); }

    function selectInputToken(token) {
      state.inputToken = token;
      document.getElementById('selectIconEl').style.background  = token.iconBg;
      document.getElementById('selectIconEl').style.color       = token.iconColor;
      document.getElementById('selectIconEl').textContent       = token.iconText;
      document.getElementById('selectLabelEl').textContent      = token.symbol;
      updateUI(); clearInputs(); updateBalances();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // TAB / OUT-TOKEN CONTROLS
    // ═══════════════════════════════════════════════════════════════════════
    function setTab(tab) {
      state.tab = tab;
      document.getElementById('tabSlider').classList.toggle('right', tab === 'out');
      document.getElementById('tabIn').classList.toggle('active',  tab === 'in');
      document.getElementById('tabOut').classList.toggle('active', tab === 'out');
      document.getElementById('tokenSelectWrap').style.display = tab === 'in'  ? '' : 'none';
      document.getElementById('outTokenPills').style.display   = tab === 'out' ? '' : 'none';
      updateUI(); clearInputs(); updateBalances();
    }

    function flipTab() { setTab(state.tab === 'in' ? 'out' : 'in'); }

    function setOutToken(token) {
      state.outToken = token;
      document.getElementById('pillUSDC').classList.toggle('active', token === 'USDC');
      document.getElementById('pillUSDT').classList.toggle('active', token === 'USDT');
      updateUI(); clearInputs(); updateBalances();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // UI RENDER
    // ═══════════════════════════════════════════════════════════════════════
    function updateUI() {
      const isIn   = state.tab === 'in';
      const inTok  = state.inputToken;
      const outTok = OUT_TOKENS[state.outToken];

      document.getElementById('fromLabel').textContent    = isIn ? `Deposit ${inTok.symbol}` : 'Return sgxUSD';
      document.getElementById('receiveLabel').textContent = isIn ? 'Receive sgxUSD' : `Receive ${outTok.symbol}`;
      document.getElementById('fromBalance').textContent  = isIn
        ? `${formatBal(state.tokenBalances[inTok.mint])} ${inTok.symbol}`
        : `${formatBal(state.tokenBalances[CONFIG.SGXUSD_MINT])} sgxUSD`;

      const fromIcon = document.getElementById('fromIcon');
      const toIcon   = document.getElementById('toIcon');
      if (isIn) {
        fromIcon.style.background = inTok.iconBg;   fromIcon.style.color = inTok.iconColor;   fromIcon.textContent = inTok.iconText;
        toIcon.style.background   = 'linear-gradient(135deg,var(--accent),var(--accent2))'; toIcon.style.color = '#080B12'; toIcon.textContent = 'sgx';
      } else {
        fromIcon.style.background = 'linear-gradient(135deg,var(--accent),var(--accent2))'; fromIcon.style.color = '#080B12'; fromIcon.textContent = 'sgx';
        toIcon.style.background   = outTok.symbol === 'USDC' ? 'linear-gradient(135deg,#2775CA,#5BA4E6)' : 'linear-gradient(135deg,#26A17B,#4FD1A5)';
        toIcon.style.color        = 'white'; toIcon.textContent = outTok.symbol === 'USDC' ? '$' : '₮';
      }

      document.getElementById('capacityVal').textContent = '— sgxUSD';
      document.getElementById('fromInput').placeholder   = '0.00';
      renderNavRate(); renderSwapBtn();
    }

    function formatBal(val) {
      if (val == null) return '0';
      return parseFloat(val).toLocaleString('en-US', { maximumFractionDigits: 4 });
    }

    // ═══════════════════════════════════════════════════════════════════════
    // INPUT HANDLING
    // ═══════════════════════════════════════════════════════════════════════
    let quoteDebounceTimer = null;

    function handleInput() {
      const raw = parseFloat(document.getElementById('fromInput').value) || 0;
      const receiveEl = document.getElementById('receiveValue');
      document.getElementById('fromInput').classList.toggle('has-value', raw > 0);
      if (raw <= 0) { receiveEl.textContent = '0'; receiveEl.classList.remove('has-value'); return; }
      if (state.navRate !== null && state.tab === 'in' && state.inputToken.symbol === 'USDC') {
        receiveEl.textContent = '~' + (raw * state.navRate).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 6 });
        receiveEl.classList.add('has-value');
      } else {
        receiveEl.textContent = 'Quoting…'; receiveEl.classList.add('has-value');
      }
      clearTimeout(quoteDebounceTimer);
      quoteDebounceTimer = setTimeout(() => fetchLiveQuote(raw), 400);
    }

    async function fetchLiveQuote(amount) {
      const receiveEl = document.getElementById('receiveValue');
      const isIn      = state.tab === 'in';
      const inTok     = isIn ? state.inputToken : { mint: CONFIG.SGXUSD_MINT, decimals: CONFIG.SGXUSD_DECIMALS };
      const outTokObj = isIn ? { mint: CONFIG.SGXUSD_MINT, decimals: CONFIG.SGXUSD_DECIMALS } : OUT_TOKENS[state.outToken];
      const amountBase = Math.round(amount * Math.pow(10, inTok.decimals));
      if (amountBase <= 0) return;
      try {
        const url  = `${CONFIG.JUPITER_QUOTE}?inputMint=${inTok.mint}&outputMint=${outTokObj.mint}&amount=${amountBase}&slippageBps=50`;
        const res  = await fetch(url);
        const text = await res.text();
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = JSON.parse(text);
        if (data.error || !data.outAmount) throw new Error(data.error ?? 'No route');
        const outRaw = parseInt(data.outAmount) / Math.pow(10, outTokObj.decimals);
        receiveEl.textContent = outRaw.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 6 });
        receiveEl.classList.add('has-value');
        if (isIn && amount > 0) { state.navRate = outRaw / amount; state.navPrice = amount / outRaw; renderNavRate(); }
      } catch (err) {
        console.warn('[GUTHIX] Live quote failed:', err.message); receiveEl.textContent = '—';
      }
    }

    function setMax() {
      const balText = document.getElementById('fromBalance').textContent;
      const num = parseFloat(balText.replace(/[^0-9.]/g, '')) || 0;
      if (num > 0) { document.getElementById('fromInput').value = num.toString(); document.getElementById('fromInput').classList.add('has-value'); handleInput(); }
    }

    function clearInputs() {
      document.getElementById('fromInput').value = '';
      document.getElementById('fromInput').classList.remove('has-value');
      document.getElementById('receiveValue').textContent = '0';
      document.getElementById('receiveValue').classList.remove('has-value');
    }

    // ═══════════════════════════════════════════════════════════════════════
    // BALANCE FETCHER — all token accounts in one RPC call
    // ═══════════════════════════════════════════════════════════════════════
    async function updateBalances() {
      if (!state.wallet) { updateUI(); return; }
      try {
        const [tokRes, solRes] = await Promise.all([
          fetch(CONFIG.RPC, { method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ jsonrpc: '2.0', id: 1, method: 'getTokenAccountsByOwner',
              params: [ state.wallet, { programId: 'TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA' }, { encoding: 'jsonParsed' } ] }) }),
          fetch(CONFIG.RPC, { method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ jsonrpc: '2.0', id: 2, method: 'getBalance', params: [state.wallet] }) }),
        ]);
        const tokData = await tokRes.json();
        const solData = await solRes.json();
        state.tokenBalances = {};
        (tokData?.result?.value || []).forEach(a => {
          const info = a.account.data.parsed.info;
          state.tokenBalances[info.mint] = info.tokenAmount.uiAmountString;
        });
        state.tokenBalances['So11111111111111111111111111111111111111112'] =
          ((solData?.result?.value ?? 0) / 1e9).toFixed(6);
      } catch (err) { console.warn('[GUTHIX] Balance fetch failed:', err.message); }
      updateUI();
    }

    // ═══════════════════════════════════════════════════════════════════════
    // POLLING
    // ═══════════════════════════════════════════════════════════════════════
    function startPolling() {
      fetchNavRate();
      setInterval(fetchNavRate, CONFIG.NAV_REFRESH_MS);

      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') {
          const now = Date.now();
          if (!state.navLastUpdated || now - state.navLastUpdated > CONFIG.NAV_REFRESH_MS) fetchNavRate();
        }
      });
    }

    // ═══════════════════════════════════════════════════════════════════════
    // BOOT
    // ═══════════════════════════════════════════════════════════════════════
    initWalletStandard();
    updateUI();
    startPolling();
  </script>

</body>
